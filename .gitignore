```gitignore
# =============================================================================
# Organizational-SACU-Mammography Project-Specific Rules
# =============================================================================

# Dataset folders
data/raw/
data/interim/
data/processed/
datasets/
dataset/
Dataset/
Datasets/

# Medical imaging formats
*.dcm
*.dicom
*.mha
*.mhd
*.nii
*.nii.gz
*.nrrd

# Large image files
*.bmp
*.tif
*.tiff

# Trained models
*.pkl
*.joblib
*.sav
*.model
*.weights
*.ckpt
*.pt
*.pth
*.h5
*.hdf5
*.keras

# Large numerical arrays
*.npy
*.npz
*.mat

# Experiment outputs
results/tables/*
results/figures/*
results/reports/*

# Keep folder structure
!results/tables/README.md
!results/figures/README.md
!results/reports/README.md

# Temporary exports
exports/
archive/
archives/
release_build/
release_package/

# Local experiment logs
logs/
*.log

# Windows
Thumbs.db
Desktop.ini

# Local path files
paths_local.py
local_config.yaml
local_paths.yaml

# IDE
.idea/
.vscode/

# Generated notebooks
*.nbconvert.ipynb

# OS files
.DS_Store

# Zenodo build artifacts
zenodo_package/
```
